# CENSUS Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database connection (Docker container)
POSTGRES_USER=census_user
POSTGRES_PASSWORD=census_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=census_db

# =============================================================================
# ACTIVE DIRECTORY CONFIGURATION  
# =============================================================================
# LDAP server for user synchronization
AD_SERVER_URL=ldap://your-domain-controller.military.net
AD_BIND_USER=cn=census_service,cn=Users,dc=military,dc=net
AD_BIND_PASSWORD=your_ad_service_password
AD_SEARCH_BASE=DC=military,DC=net

# =============================================================================
# EXTERNAL SERVICES CONFIGURATION
# =============================================================================
# AXLerate microservice for CUCM integration
AXLERATE_BASE_URL=http://axlerate:8000

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Local subnet prefix for lab safety - only scrape these IPs
LOCAL_SUBNET_PREFIX=10.55.

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# CENSUS application settings
APP_NAME=CENSUS
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Security
SECRET_KEY=your-super-secret-key-change-in-production-please

# =============================================================================
# OPTIONAL ADVANCED CONFIGURATION
# =============================================================================
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Scheduler settings
SCHEDULER_ENABLED=true
DAILY_SYNC_HOUR=3
DAILY_SYNC_MINUTE=0

# Performance tuning
MAX_DB_POOL_SIZE=20
MAX_DB_OVERFLOW=30
HTTP_TIMEOUT_SECONDS=30
SCRAPER_MAX_CONCURRENT=200
