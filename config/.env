# CENSUS Environment Configuration
# UPDATE THESE VALUES WITH YOUR ACTUAL LAB CONFIGURATION

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database connection (Docker container)
POSTGRES_USER=census_user
POSTGRES_PASSWORD=census_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=census_db

# =============================================================================
# ACTIVE DIRECTORY CONFIGURATION  
# =============================================================================
# LDAP server for user synchronization
AD_SERVER_URL=ldap://YOUR-DOMAIN-CONTROLLER.military.net
AD_BIND_USER=cn=census_service,cn=Users,dc=military,dc=net
AD_BIND_PASSWORD=YOUR_AD_SERVICE_PASSWORD
AD_SEARCH_BASE=DC=military,DC=net

# =============================================================================
# EXTERNAL SERVICES CONFIGURATION
# =============================================================================
# AXLerate microservice for CUCM integration  
AXLERATE_BASE_URL=http://axlerate:8000

# =============================================================================
# CISCO SERVERS CONFIGURATION
# =============================================================================
# UPDATE THESE WITH YOUR ACTUAL SERVER IPs

# Cisco Unified Communications Manager (CUCM)
CUCM_HOST=192.168.1.10
CUCM_USERNAME=administrator
CUCM_PASSWORD=cisco123
CUCM_PORT=8443

# Cisco Meeting Server (CMS)
CMS_HOST=192.168.1.20
CMS_USERNAME=admin
CMS_PASSWORD=admin123
CMS_PORT=8443

# MeetingPlace Server
MEETINGPLACE_HOST=192.168.1.30
MEETINGPLACE_USERNAME=admin
MEETINGPLACE_PASSWORD=admin123
MEETINGPLACE_PORT=8080

# Unified Contact Center Express (UCCX)
UCCX_HOST=192.168.1.40
UCCX_USERNAME=administrator
UCCX_PASSWORD=uccx123
UCCX_PORT=8443

# Cisco Expressway
EXPRESSWAY_HOST=192.168.1.50
EXPRESSWAY_USERNAME=admin
EXPRESSWAY_PASSWORD=expressway123
EXPRESSWAY_PORT=443

# Oracle Session Border Controller (SBC)
SBC_HOST=192.168.1.60
SBC_USERNAME=admin
SBC_PASSWORD=sbc123
SBC_PORT=8443

# TelePresence Gateway (TGW)
TGW_HOST=192.168.1.70
TGW_USERNAME=admin
TGW_PASSWORD=tgw123
TGW_PORT=8443

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# CENSUS application settings
APP_NAME=CENSUS
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Security
SECRET_KEY=change-this-secret-key-in-production

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
SCHEDULER_ENABLED=true
